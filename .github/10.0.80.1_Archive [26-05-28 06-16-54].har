\":\"Auto\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Aut\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"M2_1 Slot OpROM\",\"HelpText\":\"To select slot Storage and Network Option ROM policy. In Auto option, the default is Disabled with NVMe device, but it is Legacy with other devices.  (This item can't select Video Option ROM policy.)\",\"AttributeName\":\"SLOTOPROM01B\",\"Value\":[{\"ValueName\":\"SLOTOPROM01BDisabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"SLOTOPROM01BUEFI\",\"ValueDisplayName\":\"UEFI\"},{\"ValueName\":\"SLOTOPROM01BAuto\",\"ValueDisplayName\":\"Auto\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Aut\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"M2_2 Slot OpROM\",\"HelpText\":\"To select slot Storage and Network Option ROM policy. In Auto option, the default is Disabled with NVMe device, but it is Legacy with other devices.  (This item can't select Video Option ROM policy.)\",\"AttributeName\":\"SLOTOPROM01C\",\"Value\":[{\"ValueName\":\"SLOTOPROM01CDisabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"SLOTOPROM01CUEFI\",\"ValueDisplayName\":\"UEFI\"},{\"ValueName\":\"SLOTOPROM01CAuto\",\"ValueDisplayName\":\"Auto\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Refresh attribute registry\",\"HelpText\":\"Refreshes the attribute registry in next boot. This will be helpful for complex condition evaluation\",\"AttributeName\":\"RFWCS030\",\"Value\":[{\"ValueName\":\"RFWCS030Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"RFWCS030Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":false,\"Type\":\"Enumeration\"},{\"HelpText\":\"Re-enable Bus Master Attribute disabled during Pci enumeration for PCI Bridges after SMM Locked \",\"AttributeName\":\"PCID003\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":false,\"DisplayName\":\"BME DMA Mitigation\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"BMC Support\",\"HelpText\":\"Enable\\/Disable interfaces to communicate with BMC\",\"AttributeName\":\"IPMI600\",\"Value\":[{\"ValueName\":\"IPMI600Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"IPMI600Disabled\",\"ValueDisplayName\":\"Disabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Wait For BMC\",\"HelpText\":\"Wait For BMC response for specified time out. BMC starts at the same time when BIOS starts during AC power ON. It takes around 90 seconds to initialize Host to BMC interfaces.\",\"AttributeName\":\"IPMI601\",\"Value\":[{\"ValueName\":\"IPMI601Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"IPMI601Disabled\",\"ValueDisplayName\":\"Disabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"FRB-2 Timer\",\"HelpText\":\"Enable or Disable FRB-2 timer(POST timer)\",\"AttributeName\":\"IPMI100\",\"Value\":[{\"ValueName\":\"IPMI100Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"IPMI100Disabled\",\"ValueDisplayName\":\"Disabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"6 minute\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"FRB-2 Timer timeout\",\"HelpText\":\"Enter value Between 3 to 6 min for FRB-2 Timer Expiration value\",\"AttributeName\":\"IPMI101\",\"Value\":[{\"ValueName\":\"IPMI1013minutes\",\"ValueDisplayName\":\"3 minutes\"},{\"ValueName\":\"IPMI1014minutes\",\"ValueDisplayName\":\"4 minutes\"},{\"ValueName\":\"IPMI1015minutes\",\"ValueDisplayName\":\"5 minutes\"},{\"ValueName\":\"IPMI1016minutes\",\"ValueDisplayName\":\"6 minutes\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Do Nothin\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"FRB-2 Timer Policy\",\"HelpText\":\"Configure how the system should respond if the FRB-2 Timer expires. Not available if FRB-2 Timer is disabled.\",\"AttributeName\":\"IPMI102\",\"Value\":[{\"ValueName\":\"IPMI102DoNothing\",\"ValueDisplayName\":\"Do Nothing\"},{\"ValueName\":\"IPMI102Reset\",\"ValueDisplayName\":\"Reset\"},{\"ValueName\":\"IPMI102PowerDown\",\"ValueDisplayName\":\"Power Down\"},{\"ValueName\":\"IPMI102PowerCycle\",\"ValueDisplayName\":\"Power Cycle\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"OS Watchdog Timer\",\"HelpText\":\"If enabled, starts a BIOS timer which can only be shut off by Management Software after the OS loads.  Helps determine that the OS successfully loaded or follows the OS Boot Watchdog Timer policy.\",\"AttributeName\":\"IPMI103\",\"Value\":[{\"ValueName\":\"IPMI103Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"IPMI103Disabled\",\"ValueDisplayName\":\"Disabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"10 minute\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"OS Wtd Timer Timeout\",\"HelpText\":\"Configure the length of the OS Boot Watchdog Timer.  Not available if OS Boot Watchdog Timer is disabled.\",\"AttributeName\":\"IPMI104\",\"Value\":[{\"ValueName\":\"IPMI1045minutes\",\"ValueDisplayName\":\"5 minutes\"},{\"ValueName\":\"IPMI10410minutes\",\"ValueDisplayName\":\"10 minutes\"},{\"ValueName\":\"IPMI10415minutes\",\"ValueDisplayName\":\"15 minutes\"},{\"ValueName\":\"IPMI10420minutes\",\"ValueDisplayName\":\"20 minutes\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Rese\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"OS Wtd Timer Policy\",\"HelpText\":\"Configure how the system should respond if the OS Boot Watchdog Timer expires. Not available if OS Boot Watchdog Timer is disabled.\",\"AttributeName\":\"IPMI105\",\"Value\":[{\"ValueName\":\"IPMI105DoNothing\",\"ValueDisplayName\":\"Do Nothing\"},{\"ValueName\":\"IPMI105Reset\",\"ValueDisplayName\":\"Reset\"},{\"ValueName\":\"IPMI105PowerDown\",\"ValueDisplayName\":\"Power Down\"},{\"ValueName\":\"IPMI105PowerCycle\",\"ValueDisplayName\":\"Power Cycle\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Serial Mux\",\"HelpText\":\"Press <Enter> to enable or disable Serial Mux configuration.\",\"AttributeName\":\"IPMI400\",\"Value\":[{\"ValueName\":\"IPMI400Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"IPMI400Disabled\",\"ValueDisplayName\":\"Disabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"No Chang\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"BMC Out of band Access\",\"HelpText\":\"Enabled\\/Disabled BMC Out of band Access\",\"AttributeName\":\"IPMI520\",\"Value\":[{\"ValueName\":\"IPMI520Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"IPMI520Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"IPMI520NoChange\",\"ValueDisplayName\":\"No Change\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"N\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Manual setting IPMI LAN\",\"HelpText\":\"When Manual Setting IPMI LAN Configuration is set to default No, the IP address will follow DHCP.      If you would like to set it as Static IP, please toggle the settings to Yes, and the changes for IPMI LAN configuration will take place after rebooting.\",\"AttributeName\":\"IPMI522\",\"Value\":[{\"ValueName\":\"IPMI522Yes\",\"ValueDisplayName\":\"Yes\"},{\"ValueName\":\"IPMI522No\",\"ValueDisplayName\":\"No\"}],\"R