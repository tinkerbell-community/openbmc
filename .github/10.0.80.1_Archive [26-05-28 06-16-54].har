            "mimeType": "text/html",
            "size": 7545,
            "text": "<!doctype html>\r\n<html>\r\n<head>\r\n  <meta charset=\"utf-16\">\r\n  <meta name=\"viewport\" content=\"initial-scale=1.0\">\r\n  <meta http-equiv=\"X-UA-Compatible\" content=\"IE=EDGE\" />\r\n  <title>ASRockRack Remote BIOS Setup</title>\r\n  <link rel=\"stylesheet\" type=\"text/css\" href=\"Index.css\">\r\n  <link rel=\"icon\" href=\"Favicon.ico\" type=\"image/x-icon\" />      \r\n  <link rel=\"shortcut icon\" href=\"Favicon.ico\" type=\"image/x-icon\" />     \r\n  <script type=\"text/javascript\" src=\"Index.js\"></script>\r\n </head>\r\n<body class=\"dark\">\r\n    <div id=\"wrapper\">\r\n        <!-- For testing browser width -->\r\n        <!--div id=\"ruler\">\r\n            <p>Resize the browser. How wide am I?</p>\r\n        </div-->\r\n        <!------------------------------->\r\n        \r\n        <div class=\"max-width\">\r\n            <!-- begin side dropdown navigation -->\r\n            <div id=\"sideNav\">\r\n                <nav class=\"site\">\r\n                    <ul id=\"SideNavMenu\">\r\n                    <!-- Root Page/Menu links dynamically added here -->\r\n                    </ul>\r\n                </nav>\r\n            </div><!-- end side dropdown navigation -->\r\n        </div><!-- max-width -->\r\n      \r\n        <div id=\"site\">\r\n            <!-- begin main header -->\r\n            <header id=\"main-header\">\r\n                <div class=\"max-width\">\r\n                    <!-- left banner text-->\r\n                    <hgroup>\r\n                        <!-- form page title dynamically added here -->\r\n                        <h1><a id=\"main-header-banner\" href=\"#\">Setup</a></h1>\r\n                        <p>ASRockRack Remote Bios Setup</p>\r\n                    </hgroup>\r\n                        \r\n                    \r\n                    <!-- right menu \r\n                    <nav id=\"RightNav\">\r\n                        <span id=\"left-arrow\"></span>   \r\n                        <ul id=\"RootMenu\">\r\n                            <li><a id=\"save\" class=\"\" title=\"Save Changes\">Save Changes</a></li> \r\n                        </ul>\r\n                        <span id=\"right-arrow\"></span>\r\n                    </nav>\r\n                    -->\r\n                    \r\n                    <!-- right menu -->\r\n                    <!--div id=\"RightSave\">\r\n                        <section class=\"\" style=\"padding:4px\">\r\n                            <label id=\"SaveLabel\">Save Changes</label>\r\n                        </section>    \r\n                    </div-->\r\n                    \r\n                    <!-- right menu -->\r\n                    <!--div id=\"RightSearch\">\r\n                        <section class=\"\" style=\"padding:4px\">\r\n                            <label class=\"\">IP Address</label>\r\n                            <input id=\"nav_address\" class=\"topcoat-search-input--large\" type=\"search\" autofocus=\"\" onchange=\"validateIp(event);\" placeholder=\"Enter IP Address...\"  value=\"\" title=\"Enter Device IP Address\">\r\n                        </section>    \r\n                    </div-->\r\n\t\t\t\t\t\r\n\t\t\t\t\t\r\n                    \r\n\t\t\t\t\t\r\n                    <nav id=\"RightNav\">\r\n\t\t\t\t\t\t <a  class=\"combo\" id=\"logout\" style=\"\">Logout</a>\r\n\t\t\t\t\t\t <div class=\"combo\">Language\r\n                            <select id=\"gLanguage\" class=\"docNav\">\r\n                                <option value=\"\">en</option>\r\n                                <option value=\"\">x-UEFI-AMI</option>\r\n                                <option value=\"\">en-ES</option>\r\n                                <option value=\"\">fr-FR</option>\r\n                                <option value=\"\">zh-chs</option>\r\n                            </select>\r\n                        </div>\r\n                         <div class=\"combo-last\">Access Level\r\n                            <select id=\"SYSACS\" class=\"docNav\">\r\n                              <option value=\"0\" selected=\"selected\">Admin</option>\r\n                              <option value=\"1\">User</option>\r\n                            </select>\r\n                        </div>\r\n                        <span id=\"left-arrow\" class=\"hide\" ></span>   \r\n                        <ul id=\"RootMenu\" class=\"hide\">\r\n                        <!-- Root Page/Menu links dynamically added here -->\r\n                        </ul>\r\n                        <span id=\"right-arrow\" class=\"hide\"></span>\r\n                    </nav>\r\n\r\n                    \r\n                    <!--\r\n                    <span id=\"reset-button\">\r\n                        <label style=\"padding: 0 5px 0 0 ; \">Reset</label>\r\n                        <button id=\"reset\" class=\"topcoat-icon-button\" title=\"Remote System Reset\" style=\"cursor:pointer;\" onclick=\"doReset();\">\r\n                            <span class=\"topcoat-icon\" style=\"background-color:#d0d2d2;\"></span>\r\n                        </button>\r\n                    </span>\r\n                    -->\r\n                    \r\n                    <a id=\"logo-button\">\r\n                        <img src=\"RbLogo.png\" width=\"196\" height=\"50\">\r\n                    </a>\r\n                    \r\n                    <a id=\"hamburger-menu-button\" >\r\n                        <span class=\"line line-1\"></span>\r\n                        <span class=\"line line-2\"></span>\r\n                        <span class=\"line line-3\"></span>\r\n\t                </a>\r\n                                         \r\n                    <!-- left hamburger menu button -->\r\n                    <a id=\"slide-menu-button\" class=\"hidden\">\r\n     \t                <svg height=\"32px\" width=\"32px\">\r\n     \t\t                <path d=\"M4,10h24c1.104,0,2-0.896,2-2s-0.896-2-2-2H4C2.896,6,2,6.896,2,