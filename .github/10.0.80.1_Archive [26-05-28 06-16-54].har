ueName\":\"SECB001Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Custo\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Secure Boot Mode\",\"HelpText\":\"Secure Boot mode options:  Standard or Custom.  In Custom mode, Secure Boot Policy variables can be configured by a physically present user without full authentication\",\"AttributeName\":\"SECB002\",\"Value\":[{\"ValueName\":\"SECB002Standard\",\"ValueDisplayName\":\"Standard\"},{\"ValueName\":\"SECB002Custom\",\"ValueDisplayName\":\"Custom\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Factory Key Provision\",\"HelpText\":\"Install factory default Secure Boot keys after the platform reset and while the System is in Setup mode\",\"AttributeName\":\"SECB008\",\"Value\":[{\"ValueName\":\"SECB008Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"SECB008Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":1,\"ScalarIncrement\":1,\"UefiNamespaceId\":\"x-UEFI-AMI\",\"UpperBound\":65535,\"HelpText\":\"Configure the number of seconds to wait for the UEFI setup utility.\",\"AttributeName\":\"SETUP003\",\"LowerBound\":0,\"ReadOnly\":false,\"ResetRequired\":false,\"Type\":\"Integer\",\"DisplayName\":\"Setup Prompt Timeout\"},{\"DefaultValue\":\"O\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Bootup Num-Lock\",\"HelpText\":\"Select whether Num Lock should be turned on or off when the system boots up. \",\"AttributeName\":\"SETUP004\",\"Value\":[{\"ValueName\":\"SETUP004On\",\"ValueDisplayName\":\"On\"},{\"ValueName\":\"SETUP004Off\",\"ValueDisplayName\":\"Off\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"HelpText\":\"Enable to display the boot logo or disable to show normal POST messages.\",\"AttributeName\":\"SETUP005\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":true,\"DisplayName\":\"Full Screen Logo\",\"Type\":\"Boolean\",\"ResetRequired\":false,\"ReadOnly\":false},{\"HelpText\":\"Sets the system boot order. Each boot option is separated by semicolon which contains boot name, boot index, enabled\\/disabled\",\"AttributeName\":\"SETUP006\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"MaxLength\":8192,\"DisplayName\":\"Boot Option Priorities\",\"Type\":\"String\",\"ResetRequired\":false,\"ReadOnly\":false},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Fast Boot\",\"HelpText\":\"Fast Boot minimizes your computer's boot time. In fast mode you may not boot from an USB storage device. Ultra Fast mode is only supported by Windows 8 and the VBIOS must support UEFI GOP if you are using an external graphics card. Please notice that Ultra Fast mode will boot so fast that the only way to enter this UEFI Setup Utility is to Clear CMOS or run the Restart to UEFI utility in Windows.\",\"AttributeName\":\"PTT000\",\"Value\":[{\"ValueName\":\"PTT000Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"PTT000Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Last Boot SATA Devices Onl\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\" SATA Support\",\"HelpText\":\"If Last Boot SATA Devices Only, Only last boot SATA device will be available in Post. If All SATA Devices, all SATA devices will be available in OS and Post.\",\"AttributeName\":\"PTT001\",\"Value\":[{\"ValueName\":\"PTT001LastBootSATADevicesOnly\",\"ValueDisplayName\":\"Last Boot SATA Devices Only\"},{\"ValueName\":\"PTT001AllSATADevices\",\"ValueDisplayName\":\"All SATA Devices\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\" NVMe Support\",\"HelpText\":\"If Disabled, NVMe device will be skipped.\",\"AttributeName\":\"PTT006\",\"Value\":[{\"ValueName\":\"PTT006Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"PTT006Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"EFI Drive\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\" VGA Support\",\"HelpText\":\"If Auto, only install Legacy OpRom with Legacy OS and logo would NOT be shown during post. Efi driver will still be installed with EFI OS.\",\"AttributeName\":\"PTT004\",\"Value\":[{\"ValueName\":\"PTT004Auto\",\"ValueDisplayName\":\"Auto\"},{\"ValueName\":\"PTT004EFIDriver\",\"ValueDisplayName\":\"EFI Driver\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Full Initia\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\" USB Support\",\"HelpText\":\"If Disabled, all USB devices will NOT be available until after OS boot. If Partial Initial, USB Mass Storage and specific USB port\\/device will NOT be available before OS boot. If Enabled, all USB devices will be available in OS and Post.\",\"AttributeName\":\"PTT002\",\"Value\":[{\"ValueName\":\"PTT002Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"PTT002FullInitial\",\"ValueDisplayName\":\"Full Initial\"},{\"ValueName\":\"PTT002PartialInitial\",\"ValueDisplayName\":\"Partial Initial\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\" PS2 Devices Support\",\"HelpText\":\"If Disabled, PS2 devices will be skipped.\",\"AttributeName\":\"PTT003\",\"Value\":[{\"ValueName\":\"PTT003Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"PTT003Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\" Network Stack Driver Support\",\"HelpText\":\"If Disabled, NetWork Stack Driver will be skipped.\",\"AttributeName\":\"PTT005\",\"Value\":[{\"ValueName\":\"PTT005Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"PTT005Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Redirection Support\",\"HelpText\":\"If disable, Redirection function will be disabled.\",\"AttributeName\":\"PTT010\",\"Value\":[{\"ValueName\":\"PTT010Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"PTT010Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"UEFI and Legac\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Boot option filter\",\"HelpText\":\"This option controls Legacy\\/UEFI ROMs priority\",\"AttributeName\":\"CSM006\",\"Value\":[{\"ValueName\":\"CSM006UEFIandLegacy\",\"ValueDisplayName\":\"UEFI and Legacy\"},{\"ValueName\":\"CSM006Legacyonly\",\"ValueDisplayName\":\"Legacy only\"},{\"ValueName\":\"CSM006UEFIonly\",\"ValueDisplayName\":\"UEFI only\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Boot From Onboard LAN(X550)\",\"HelpText\":\"To enable\\/disable the boot from onboard LAN function.   Press <Ctrl - S> to enter LAN Rom during UEFI POST process.   Press <Ctrl - D> to enter iSCSI Rom during UEFI POST process.\",\"AttributeName\":\"BFOL000\",\"Value\":[{\"ValueName\":\"BFOL000Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"BFOL000OnboardLAN1PXE\",\"ValueDisplayName\":\"Onboard LAN1 PXE\"},{\"ValueName\":\"BFOL000OnboardLAN2PXE\",\"ValueDisplayName\":\"Onboard LAN2 PXE\"},{\"ValueName\":\"BFOL000OnboardLANUEFIPXE\",\"ValueDisplayName\":\"Onboard LAN UEFI PXE\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\