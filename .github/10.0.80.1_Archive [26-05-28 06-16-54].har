 Hotplug Mode Control\",\"AttributeName\":\"CRB087\",\"Value\":[{\"ValueName\":\"CRB087Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"CRB087HotplugBasic\",\"ValueDisplayName\":\"Hotplug Basic\"},{\"ValueName\":\"CRB087HotplugServer\",\"ValueDisplayName\":\"Hotplug Server\"},{\"ValueName\":\"CRB087HotplugEnhanced\",\"ValueDisplayName\":\"Hotplug Enhanced\"},{\"ValueName\":\"CRB087HotplugInboard\",\"ValueDisplayName\":\"Hotplug Inboard\"},{\"ValueName\":\"CRB087Auto\",\"ValueDisplayName\":\"Auto\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"HelpText\":\"Enable or Disable Serial Port (COM)\",\"AttributeName\":\"GSIO201\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":true,\"DisplayName\":\"Serial Port\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"DefaultValue\":\"3F8h\\/IRQ\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Serial Port Address\",\"HelpText\":\"Select an optimal settings for Super IO Device\",\"AttributeName\":\"SUPERIO001\",\"Value\":[{\"ValueName\":\"SUPERIO0013F8hIRQ4\",\"ValueDisplayName\":\"3F8h\\/IRQ4\"},{\"ValueName\":\"SUPERIO0013E8hIRQ4\",\"ValueDisplayName\":\"3E8h\\/IRQ4\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"HelpText\":\"Enable or Disable SOL Port\",\"AttributeName\":\"SUPERIO002\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":true,\"DisplayName\":\"SOL Port\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"DefaultValue\":\"2F8h\\/IRQ\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Serial Port Address\",\"HelpText\":\"Select an optimal settings for Super IO Device\",\"AttributeName\":\"SUPERIO004\",\"Value\":[{\"ValueName\":\"SUPERIO0042F8hIRQ3\",\"ValueDisplayName\":\"2F8h\\/IRQ3\"},{\"ValueName\":\"SUPERIO0042E8hIRQ3\",\"ValueDisplayName\":\"2E8h\\/IRQ3\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"HelpText\":\"Console Redirection Enable or Disable.\",\"AttributeName\":\"TER001\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":false,\"DisplayName\":\"Console Redirection\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"HelpText\":\"Console Redirection Enable or Disable.\",\"AttributeName\":\"TER002\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":false,\"DisplayName\":\"Console Redirection\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"HelpText\":\"Console Redirection Enable or Disable.\",\"AttributeName\":\"TER010\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":true,\"DisplayName\":\"Console Redirection EMS\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"DefaultValue\":\"COM\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Out-of-Band Mgmt Port\",\"HelpText\":\"Microsoft Windows Emergency Management Services (EMS) allows for remote management of a Windows Server OS through a serial port.\",\"AttributeName\":\"TER06B\",\"Value\":[{\"ValueName\":\"TER06BCOM1\",\"ValueDisplayName\":\"COM1\"},{\"ValueName\":\"TER06BSOL\",\"ValueDisplayName\":\"SOL\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"VT-UTF\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Terminal Type EMS\",\"HelpText\":\"VT-UTF8 is the preferred terminal type for out-of-band management. The next best choice is VT100+ and then VT100. See above, in Console Redirection Settings page, for more Help with Terminal Type\\/Emulation.\",\"AttributeName\":\"TER011\",\"Value\":[{\"ValueName\":\"TER011VT100\",\"ValueDisplayName\":\"VT100\"},{\"ValueName\":\"TER011VT100\",\"ValueDisplayName\":\"VT100+\"},{\"ValueName\":\"TER011VTUTF8\",\"ValueDisplayName\":\"VT-UTF8\"},{\"ValueName\":\"TER011ANSI\",\"ValueDisplayName\":\"ANSI\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"11520\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Bits per second EMS\",\"HelpText\":\"Selects serial port transmission speed. The speed must be matched on the other side. Long or noisy lines may require lower speeds.\",\"AttributeName\":\"TER0020\",\"Value\":[{\"ValueName\":\"TER00209600\",\"ValueDisplayName\":\"9600\"},{\"ValueName\":\"TER002019200\",\"ValueDisplayName\":\"19200\"},{\"ValueName\":\"TER002057600\",\"ValueDisplayName\":\"57600\"},{\"ValueName\":\"TER0020115200\",\"ValueDisplayName\":\"115200\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Non\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Flow Control EMS\",\"HelpText\":\"Flow control can prevent data loss from buffer overflow. When sending data, if the receiving buffers are full, a 'stop' signal can be sent to stop the data flow. Once the buffers are empty, a 'start' signal can be sent to re-start the flow. Hardware flow control uses two wires to send start\\/stop signals.\",\"AttributeName\":\"TER05C\",\"Value\":[{\"ValueName\":\"TER05CNone\",\"ValueDisplayName\":\"None\"},{\"ValueName\":\"TER05CHardwareRTSCTS\",\"ValueDisplayName\":\"Hardware RTS\\/CTS\"},{\"ValueName\":\"TER05CSoftwareXonXoff\",\"ValueDisplayName\":\"Software Xon\\/Xoff\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"COM\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Redirection COM Port\",\"HelpText\":\"Select a COM port to display redirection of Legacy OS and Legacy OPROM Messages\",\"AttributeName\":\"TER0A8\",\"Value\":[{\"ValueName\":\"TER0A8COM1\",\"ValueDisplayName\":\"COM1\"},{\"ValueName\":\"TER0A8SOL\",\"ValueDisplayName\":\"SOL\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"80x2\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Resolution\",\"HelpText\":\"On Legacy OS, the Number of Rows and Columns supported redirection\",\"AttributeName\":\"TER07A\",\"Value\":[{\"ValueName\":\"TER07A80x24\",\"ValueDisplayName\":\"80x24\"},{\"ValueName\":\"TER07A80x25\",\"ValueDisplayName\":\"80x25\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Always Enabl\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Redirect After POST\",\"HelpText\":\"When Bootloader is selected, then Legacy Console Redirection is disabled before booting to legacy OS. When Always Enable is selected, then Legacy Console Redirection is enabled for legacy OS. Default setting for this option is set to Always Enable.\",\"AttributeName\":\"TER0A7\",\"Value\":[{\"ValueName\":\"TER0A7AlwaysEnable\",\"ValueDisplayName\":\"Always Enable\"},{\"ValueName\":\"TER0A7BootLoader\",\"ValueDisplayName\":\"BootLoader\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"VT100\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Terminal Type\",\"HelpText\":\"Emulation: ANSI: Extended ASCII char set. VT100: ASCII char set. VT100+: Extends VT100 to support color, function keys, etc. VT-UTF8: Uses UTF8 encoding to map Unicode chars onto 1 or more bytes.\",\"AttributeName\":\"TER012\",\"Value\":[{\"ValueName\":\"TER012VT100\",\"ValueDisplayName\":\"VT100\"},{\"ValueName\":\"TER012VT100\",\"ValueDisplayName\":\"VT100+\"},{\"ValueName\":\"TER012VTUTF8\",\"ValueDisplayName\":\"VT-UTF8\"},{\"ValueName\":\"TER012ANSI\",\"ValueDisplayName\":\"ANSI\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"11520\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Bits per second\",\"HelpText\":\"Selects serial port transmission speed. The speed must be matched on the other side. Long or noisy lines may require lower speeds.\",\"AttributeName\":\"TER0021\",\"Value\":[{\"ValueName\":\"TER00219600\",\"ValueDisplayName\":\"9600\"},{\"ValueName\":\"TER002119200\",\"ValueDisplayName\":\"19200\"},{\"ValueName\":\"TER002138400\",\"ValueDisplayName\":\"38400\"},{\"ValueName\":\"TER002157600\",\"ValueDisplayName\":\"57600\"},{\"ValueName\":\"TER0021115200\",\"ValueDisplayName\":\"115200\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Data Bits\",\"HelpText\":\"Data Bits\",\"AttributeName\":\"TER030\",\"Value\":[{\"ValueName\":\"TER0307\",\"ValueDisplayName\":\"7\"},{\"ValueName\":\"TER0308\",\"ValueDisplayName\":\"8\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Non\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Parity\",\"HelpText\":\"A parity bit can be sent with the data bits to detect some transmission errors. Even: parity bit is 0 if the num of 1's in the data bits is even. Odd: parity bit is 0 if num of 1's in the data bits is odd.  Mark: parity bit is always 1. Space: Parity bit is always 0. Mark and Space Parity do not allow for error detection. They can be used as an additional data bit.\",\"AttributeName\":\"TER03F\",\"Value\":[{\"ValueName\":\"TER03FNone\",\"ValueDisplayName\":\"None\"},{\"ValueName\":\"TER03FEven\",\"ValueDisplayName\":\"Even\"},{\"ValueName\":\"TER03FOdd\",\"ValueDisplayName\":\"Odd\"},{\"ValueName\":\"TER03FMark\",\"ValueDisplayName\":\"Mark\"},{\"ValueName\":\"TER03FSpace\",\"ValueDisplayName\":\"Space\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Stop Bits\",\"HelpText\":\"Stop bits indicate the end of a serial data packet. (A start bit indicates the beginning). The standard setting is 1 stop bit. Communication with slow devices may require more than 1 stop bit.\",\"AttributeName\":\"TER04E\",\"Value\":[{\"ValueName\":\"TER04E1\",\"ValueDisplayName\":\"1\"},{\"ValueName\":\"TER04E2\",\"ValueDisplayName\":\"2\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Non\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Flow Control\",\"HelpText\":\"Flow control can prevent data loss from buffer overflow. When sending data, if the receiving buffers are full, a 'stop' signal can be sent to stop the data flow. Once the buffers are empty, a 'start' signal can be sent to re-start the flow. Hardware flow control uses two wires to send start\\/stop signals.\",\"AttributeName\":\"TER05D\",\"Value\":[{\"ValueName\":\"TER05DNone\",\"ValueDisplayName\":\"None\"},{\"ValueName\":\"TER05DHardwareRTSCTS\",\"ValueDisplayName\":\"Hardware RTS\\/CTS\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"HelpText\":\"Enable VT-UTF8 Combination Key Support for ANSI\\/VT100 terminals\",\"AttributeName\":\"TER07B\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":true,\"DisplayName\":\"VT-UTF8 Combo Key Support\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"HelpText\":\"With this mode enabled only text will be sent. This is to capture Terminal data.\",\"AttributeName\":\"TER089\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":false,\"DisplayName\":\"Recorder Mode\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"HelpText\":\"Enables or disables extended terminal resolution\",\"AttributeName\":\"TER06c\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":false,\"DisplayName\":\"Resolution 100x31\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"DefaultValue\":\"VT10\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Putty KeyPad\",\"HelpText\":\"Select FunctionKey and KeyPad on Putty.\",\"AttributeName\":\"TER098\",\"Value\":[{\"ValueName\":\"TER098VT100\",\"ValueDisplayName\":\"VT100\"},{\"ValueName\":\"TER098LINUX\",\"ValueDisplayName\":\"LINUX\"},{\"ValueName\":\"TER098XTERMR6\",\"ValueDisplayName\":\"XTERMR6\"},{\"ValueName\":\"TER098SCO\",\"ValueDisplayName\":\"SCO\"},{\"ValueName\":\"TER098ESCN\",\"ValueDisplayName\":\"ESCN\"},{\"ValueName\":\"TER098VT400\",\"ValueDisplayName\":\"VT400\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"VT100\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Terminal Type\",\"HelpText\":\"Emulation: ANSI: Extended ASCII char set. VT100: ASCII char set. VT100+: Extends VT100 to support color, function keys, etc. VT-UTF8: Uses UTF8 encoding to map Unicode chars onto 1 or more bytes.\",\"AttributeName\":\"TER013\",\"Value\":[{\"ValueName\":\"TER013VT100\",\"ValueDisplayName\":\"VT100\"},{\"ValueName\":\"TER013VT100\",\"ValueDisplayName\":\"VT100+\"},{\"ValueName\":\"TER013VTUTF8\",\"ValueDisplayName\":\"VT-UTF8\"},{\"ValueName\":\"TER013ANSI\",\"ValueDisplayName\":\"ANSI\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"11520\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Bits per second\",\"HelpText\":\"Selects serial port transmission speed. The speed must be matched on the other side. Long or noisy lines may require lower speeds.\",\"AttributeName\":\"TER0022\",\"Value\":[{\"ValueName\":\"TER00229600\",\"ValueDisplayName\":\"9600\"},{\"ValueName\":\"TER002219200\",\"ValueDisplayName\":\"19200\"},{\"ValueName\":\"TER002238400\",\"ValueDisplayName\":\"38400\"},{\"ValueName\":\"TER002257600\",\"ValueDisplayName\":\"57600\"},{\"ValueName\":\"TER0022115200\",\"ValueDisplayName\":\"115200\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Data Bits\",\"HelpText\":\"Data Bits\",\"AttributeName\":\"TER031\",\"Value\":[{\"ValueName\":\"TER0317\",\"ValueDisplayName\":\"7\"},{\"ValueName\":\"TER0318\",\"ValueDisplayName\":\"8\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Non\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Parity\",\"HelpText\":\"A parity bit can be sent with the data bits to detect some transmission errors. Even: parity bit is 0 if the num of 1's in the data bits is even. Odd: parity bit is 0 if num of 1's in the data bits is odd.  Mark: parity bit is always 1. Space: Parity bit is always 0. Mark and Space Parity do not allow for error detection. They can be used as an additional data bit.\",\"AttributeName\":\"TER040\",\"Value\":[{\"ValueName\":\"TER040None\",\"ValueDisplayName\":\"None\"},{\"ValueName\":\"TER040Even\",\"ValueDisplayName\":\"Even\"},{\"ValueName\":\"TER040Odd\",\"ValueDisplayName\":\"Odd\"},{\"ValueName\":\"TER040Mark\",\"ValueDisplayName\":\"Mark\"},{\"ValueName\":\"TER040Space\",\"ValueDisplayName\":\"Space\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Stop Bits\",\"HelpText\":\"Stop bits indicate the end of a serial data packet. (A start bit indicates the beginning). The standard setting is 1 stop bit. Communication with slow devices may require more than 1 stop bit.\",\"AttributeName\":\"TER04F\",\"Value\":[{\"ValueName\":\"TER04F1\",\"ValueDisplayName\":\"1\"},{\"ValueName\":\"TER04F2\",\"ValueDisplayName\":\"2\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Non\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Flow Control\",\"HelpText\":\"Flow control can prevent data loss from buffer overflow. When sending data, if the receiving buffers are full, a 'stop' signal can be sent to stop the data flow. Once the buffers are empty, a 'start' signal can be sent to re-start the flow. Hardware flow control uses two wires to send start\\/stop signals.\",\"AttributeName\":\"TER05E\",\"Value\":[{\"ValueName\":\"TER05ENone\",\"ValueDisplayName\":\"None\"},{\"ValueName\":\"TER05EHardwareRTSCTS\",\"ValueDisplayName\":\"Hardware RTS\\/CTS\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"HelpText\":\"Enable VT-UTF8 Combination Key Support for ANSI\\/VT100 terminals\",\"AttributeName\":\"TER07C\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":true,\"DisplayName\":\"VT-UTF8 Combo Key Support\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"HelpText\":\"With this mode enabled only text will be sent. This is to capture Terminal data.\",\"AttributeName\":\"TER08A\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":false,\"DisplayName\":\"Recorder Mode\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"HelpText\":\"Enables or disables extended terminal resolution\",\"AttributeName\":\"TER06D\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":false,\"DisplayName\":\"Resolution 100x31\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"DefaultValue\":\"VT10\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Putty KeyPad\",\"HelpText\":\"Select FunctionKey and KeyPad on Putty.\",\"AttributeName\":\"TER099\",\"Value\":[{\"ValueName\":\"TER099VT100\",\"ValueDisplayName\":\"VT100\"},{\"ValueName\":\"TER099LINUX\",\"ValueDisplayName\":\"LINUX\"},{\"ValueName\":\"TER099XTERMR6\",\"ValueDisplayName\":\"XTERMR6\"},{\"ValueName\":\"TER099SCO\",\"ValueDisplayName\":\"SCO\"},{\"ValueName\":\"TER099ESCN\",\"ValueDisplayName\":\"ESCN\"},{\"ValueName\":\"TER099VT400\",\"ValueDisplayName\":\"VT400\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"PState \",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"PPC Adjustment\",\"HelpText\":\"Provide to adjust _PPC object.\",\"AttributeName\":\"CPU003\",\"Value\":[{\"ValueName\":\"CPU003PState0\",\"ValueDisplayName\":\"PState 0\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"NX Mode\",\"HelpText\":\"Enable\\/disable No-execute page protection Function\",\"AttributeName\":\"CPU004\",\"Value\":[{\"ValueName\":\"CPU004Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"CPU004Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Unknown Devic\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Output Select\",\"HelpText\":\"Output Interface\",\"AttributeName\":\"GOPP001\",\"Value\":[{\"ValueName\":\"GOPP001UnknownDevice\",\"ValueDisplayName\":\"Unknown Device\"}],\"ReadOnly\":false,\"ResetRequired\":false,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Debug Port Table\",\"HelpText\":\"Debug Port Table\",\"AttributeName\":\"DBG002\",\"Value\":[{\"ValueName\":\"DBG002Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"DBG002Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Debug Port Table 2\",\"HelpText\":\"Debug Port Table 2\",\"AttributeName\":\"DBG003\",\"Value\":[{\"ValueName\":\"DBG003Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"DBG003Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"HelpText\":\"Enables or Disables Lock of Legacy Resources\",\"AttributeName\":\"GSIO020\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DefaultValue\":false,\"DisplayName\":\"Lock Legacy Resources\",\"Type\":\"Boolean\",\"ResetRequired\":true,\"ReadOnly\":false},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"USB Support\",\"HelpText\":\"USB Support Parameters\",\"AttributeName\":\"USB000\",\"Value\":[{\"ValueName\":\"USB000Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"USB000Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Legacy USB Support\",\"HelpText\":\"Enables Legacy USB support. AUTO option disables legacy support if no USB devices are connected. DISABLE option will keep USB devices available only for EFI applications.\",\"AttributeName\":\"USB002\",\"Value\":[{\"ValueName\":\"USB002Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"USB002UEFISetupOnly\",\"ValueDisplayName\":\"UEFI Setup Only\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"HiSpee\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"USB 2.0 Controller Mode\",\"HelpText\":\"Configures the USB 2.0 controller in HiSpeed (480Mbps) or FullSpeed (12Mbps).\",\"AttributeName\":\"USB00E\",\"Value\":[{\"ValueName\":\"USB00EHiSpeed\",\"ValueDisplayName\":\"HiSpeed\"},{\"ValueName\":\"USB00EFullSpeed\",\"ValueDisplayName\":\"FullSpeed\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"Legacy USB 3.0 Support\",\"HelpText\":\"Enable or disable Legacy OS Support for USB 3.0 devices.\",\"AttributeName\":\"USB001\",\"Value\":[{\"ValueName\":\"USB001Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"USB001Disabled\",\"ValueDisplayName\":\"Disabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Enable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"XHCI Hand-off\",\"HelpText\":\"This is a workaround for OSes without XHCI hand-off support. The XHCI ownership change should be claimed by XHCI driver.\",\"AttributeName\":\"USB003\",\"Value\":[{\"ValueName\":\"USB003Enabled\",\"ValueDisplayName\":\"Enabled\"},{\"ValueName\":\"USB003Disabled\",\"ValueDisplayName\":\"Disabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"DefaultValue\":\"Disable\",\"UefiNamespaceId\":\"x-UEFI-AMI\",\"DisplayName\":\"EHCI Hand-off\",\"HelpText\":\"This is a workaround for OSes without EHCI hand-off support. The EHCI ownership change should be claimed by EHCI driver.\",\"AttributeName\":\"USB004\",\"Value\":[{\"ValueName\":\"USB004Disabled\",\"ValueDisplayName\":\"Disabled\"},{\"ValueName\":\"USB004Enabled\",\"ValueDisplayName\":\"Enabled\"}],\"ReadOnly\":false,\"ResetRequired\":true,\"Type\":\"Enumeration\"},{\"Defau